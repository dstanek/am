FROM ubuntu:25.10

# Prevent interactive prompts during package installation
ENV DEBIAN_FRONTEND=noninteractive

RUN <<EOF
set -e

# System packages: dev tools Claude commonly needs
apt-get update && apt-get install -y \
    ca-certificates \
    curl \
    wget \
    gnupg \
    git \
    build-essential \
    python3 \
    python3-pip \
    python3-venv \
    ripgrep \
    fd-find \
    jq \
    unzip \
    less \
    neovim \
    ssh
ln -s /usr/bin/fdfind /usr/local/bin/fd

# Install Node.js LTS via NodeSource
curl -fsSL https://deb.nodesource.com/setup_lts.x | bash -
apt-get install -y nodejs

# Install Claude Code
npm install -g @anthropic-ai/claude-code

# Install jj (Jujutsu VCS)
JJ_VERSION=$(curl -fsSLI -o /dev/null -w '%{url_effective}' https://github.com/jj-vcs/jj/releases/latest | sed 's|.*/tag/||' | tr -d '[:space:]')
JJ_ARCH=$(uname -m)
curl -fsSL "https://github.com/jj-vcs/jj/releases/download/${JJ_VERSION}/jj-${JJ_VERSION}-${JJ_ARCH}-unknown-linux-musl.tar.gz" \
    | tar -xz -C /usr/local/bin

rm -rf /var/lib/apt/lists/*
EOF

# Create a non-root user so Claude Code can run with --dangerously-skip-permissions
# Ubuntu 25.10+ ships with an 'ubuntu' user at UID 1000; remove it and create 'am' instead
RUN userdel -r ubuntu 2>/dev/null || true \
 && useradd -m -u 1000 -s /bin/bash am \
 && mkdir -p /workspace && chown am:am /workspace

USER am
ENV HOME=/home/am

# ~/.claude will be mounted by `am` at runtime — no credentials baked in
WORKDIR /workspace
