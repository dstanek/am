FROM ubuntu:25.10

# Prevent interactive prompts during package installation
ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y \
    ca-certificates \
    curl \
    git \
 && rm -rf /var/lib/apt/lists/*

# Create a non-root user so Claude Code can run with --dangerously-skip-permissions
# Ubuntu 25.10+ ships with an 'ubuntu' user at UID 1000; remove it and create 'am' instead
RUN userdel -r ubuntu 2>/dev/null || true \
 && useradd -m -u 1000 -s /bin/bash am \
 && mkdir -p /home/am/.config /workspace \
 && chown -R am:am /home/am/.config /workspace

USER am
ENV HOME=/home/am

# Install Claude Code via native installer (no Node.js/npm required)
RUN curl -fsSL https://claude.ai/install.sh | bash

ENV PATH="/home/am/.local/bin:${PATH}"
ENV DISABLE_AUTOUPDATER=1

# ~/.claude will be mounted by `am` at runtime — no credentials baked in
WORKDIR /workspace
